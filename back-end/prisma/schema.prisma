generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  cep      String
  profissao String
  courses  Course[] 
}

model Course {
  id          String @id @default(uuid())
  title       String
  hours       Int
  lessons     Int
  level       String
  createdAt   String
  profissao   String
  description String
  price       Float
  language    String 

  userId String
  user   User @relation(fields: [userId], references: [id])
}